FROM python:3.11.11-slim-bookworm@sha256:081075da77b2b55c23c088251026fb69a7b2bf92471e491ff5fd75c192fd38e5

LABEL org.opencontainers.image.title="Orbit Wars Agent Sandbox" \
      org.opencontainers.image.description="Fixed PyTorch 2.5.1 phase-one expert runtime" \
      org.opencontainers.image.version="py311-torch251-v1"

COPY requirements-torch251.lock /tmp/requirements-torch251.lock
RUN python -m pip install \
    --no-cache-dir \
    --disable-pip-version-check \
    --requirement /tmp/requirements-torch251.lock \
    && rm /tmp/requirements-torch251.lock

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/opt/orbit-sandbox \
    ORBIT_AGENT_ROOT=/strategy

WORKDIR /opt/orbit-sandbox
COPY orbit_agent_sandbox /opt/orbit-sandbox/orbit_agent_sandbox

USER 65532:65532
ENTRYPOINT ["python", "-m", "orbit_agent_sandbox.runner"]

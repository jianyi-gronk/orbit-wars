# Copy to .env for local overrides. Values below are local-only placeholders.
APP_ENV=local
COMPOSE_PROJECT_NAME=orbit-wars
DATABASE_URL=postgresql://orbit_wars:local_postgres_password@localhost:5432/orbit_wars
OIDC_AUDIENCE=orbit-wars-local
OIDC_ISSUER=https://identity.example.invalid
OIDC_JWKS_URL=https://identity.example.invalid/.well-known/jwks.json
OIDC_CLIENT_ID=orbit-wars-web-local
ORBIT_API_INTERNAL_BASE=http://127.0.0.1:8000
ORBIT_DEV_AUTH=true
NEXT_PUBLIC_ORBIT_DEV_SUBJECT=local-commander
NEXT_PUBLIC_ENABLE_HUMAN_PLAY=false
NEXT_PUBLIC_SUPPORT_EMAIL=support@orbit-wars.example
POSTGRES_DB=orbit_wars
POSTGRES_PASSWORD=local_postgres_password
POSTGRES_PORT=5432
POSTGRES_USER=orbit_wars
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
ORBIT_TURN_SECONDS=10
S3_ACCESS_KEY=orbit_wars_local
S3_BUCKET=orbit-wars-local
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_SECRET_KEY=local_object_storage_secret
S3_API_PORT=9000
S3_CONSOLE_PORT=9001
